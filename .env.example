# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
BOT_ID=your_telegram_bot_token_here

# Get your chat ID by messaging your bot and visiting:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
CHAT_ID=your_telegram_chat_id_here

# Optional: GitHub Personal Access Token (only needed for cleanup_old_runs.py)
PERSONAL_ACCESS_TOKEN=your_github_token_here
